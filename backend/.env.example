# ===== Server =====
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Comma-separated list of allowed origins for CORS (Flutter web / admin)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ===== Database (PostgreSQL) =====
# Either provide DATABASE_URL or the individual PG* values.
DATABASE_URL=postgres://icms:icms_password@localhost:5432/icms
PGHOST=localhost
PGPORT=5432
PGUSER=icms
PGPASSWORD=icms_password
PGDATABASE=icms
# Set to "true" on managed/SSL databases
PGSSL=false

# ===== Auth / JWT =====
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
BCRYPT_ROUNDS=12

# ===== File Storage =====
# local | s3
STORAGE_DRIVER=local
STORAGE_DIR=./storage
# Max upload size in MB
MAX_UPLOAD_MB=200

# ===== First Admin (used by `npm run seed`) =====
SEED_ADMIN_NAME=Owner Admin
SEED_ADMIN_EMAIL=admin@interior.local
SEED_ADMIN_PHONE=+910000000000
SEED_ADMIN_PASSWORD=Admin@12345

# ===== Push Notifications (Firebase Cloud Messaging V1) =====
# Paste the entire Firebase service account JSON as one line.
# Get it from: Firebase Console > Project Settings > Service Accounts > Generate new private key
GOOGLE_SERVICE_ACCOUNT_JSON=
# Legacy key (deprecated, leave empty if using V1)
FCM_SERVER_KEY=


# ===== Security (FIX-09) =====
INTERNAL_HEALTH_SECRET=change-me-random-32chars

# ===== SMS / OTP (FEATURE-06) =====
SMS_PROVIDER=msg91
MSG91_API_KEY=
MSG91_SENDER_ID=ICMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ===== Jobs / Cron (FEATURE-01, FEATURE-11) =====
REPORT_DEADLINE_HOUR=21
DIGEST_HOUR=8
ACTIVITY_ARCHIVE_DAYS=90


# ===== Public base URL (for absolute file links in responses) =====
# e.g. https://icms-backend-s2va.onrender.com  (no trailing slash)
PUBLIC_BASE_URL=
